APP_NAME="Celeris API"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=UTC
APP_VERSION=1.0.0

DB_DEFAULT=main
DB_SQLITE_PATH=var/database.sqlite

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=app
MYSQL_USERNAME=root
MYSQL_PASSWORD=

MARIADB_HOST=127.0.0.1
MARIADB_PORT=3306
MARIADB_DATABASE=app
MARIADB_USERNAME=root
MARIADB_PASSWORD=

PGSQL_HOST=127.0.0.1
PGSQL_PORT=5432
PGSQL_DATABASE=app
PGSQL_USERNAME=postgres
PGSQL_PASSWORD=

SQLSRV_HOST=127.0.0.1
SQLSRV_PORT=1433
SQLSRV_DATABASE=app
SQLSRV_USERNAME=sa
SQLSRV_PASSWORD=

FIREBIRD_HOST=127.0.0.1
FIREBIRD_PORT=3050
FIREBIRD_DATABASE=/var/lib/firebird/data/app.fdb
FIREBIRD_USERNAME=SYSDBA
FIREBIRD_PASSWORD=masterkey
FIREBIRD_CHARSET=UTF8
FIREBIRD_DSN=
FIREBIRD_ID_STRATEGY=auto
FIREBIRD_ID_SEQUENCE=
FIREBIRD_ID_SEQUENCE_PATTERN=

IBM_HOST=127.0.0.1
IBM_PORT=50000
IBM_DATABASE=SAMPLE
IBM_USERNAME=db2inst1
IBM_PASSWORD=
IBM_PROTOCOL=TCPIP
IBM_DSN=
IBM_ID_STRATEGY=auto
IBM_ID_SEQUENCE=
IBM_ID_SEQUENCE_PATTERN=

OCI_HOST=127.0.0.1
OCI_PORT=1521
OCI_DATABASE=XE
OCI_SERVICE_NAME=
OCI_SID=
OCI_USERNAME=system
OCI_PASSWORD=
OCI_CHARSET=AL32UTF8
OCI_DSN=
OCI_ID_STRATEGY=auto
OCI_ID_SEQUENCE=
OCI_ID_SEQUENCE_PATTERN=

SECURITY_AUTH_JWT_ENABLED=false
SECURITY_AUTH_OPAQUE_ENABLED=false
SECURITY_AUTH_COOKIE_SESSION_ENABLED=false
SECURITY_AUTH_API_TOKEN_ENABLED=false
SECURITY_AUTH_MTLS_ENABLED=false
SECURITY_CSRF_ENABLED=false

SECURITY_RATE_LIMIT_LIMIT=120
SECURITY_RATE_LIMIT_WINDOW_SECONDS=60
SECURITY_RATE_LIMIT_BURST=0

JWT_SECRET=
JWT_LEEWAY_SECONDS=30
JWT_TTL_SECONDS=3600

DEMO_AUTH_USERNAME=demo
DEMO_AUTH_PASSWORD_HASH=$2y$12$9GK/vlsIdSj5KeClYZyTu.ZDgGUdh0PsyNprCZsHo37ykuPQ4AWfS

NOTIFICATIONS_DEFAULT_CHANNEL=null
NOTIFICATIONS_NULL_ENABLED=true

NOTIFICATIONS_SMTP_ENABLED=false
NOTIFICATIONS_SMTP_HOST=127.0.0.1
NOTIFICATIONS_SMTP_PORT=587
NOTIFICATIONS_SMTP_USERNAME=
NOTIFICATIONS_SMTP_PASSWORD=
NOTIFICATIONS_SMTP_ENCRYPTION=tls
NOTIFICATIONS_SMTP_TIMEOUT_SECONDS=10
NOTIFICATIONS_SMTP_EHLO_DOMAIN=localhost
NOTIFICATIONS_FROM_ADDRESS=no-reply@example.com
NOTIFICATIONS_FROM_NAME=Celeris

NOTIFICATIONS_IN_APP_ENABLED=false
NOTIFICATIONS_IN_APP_CONNECTION=
NOTIFICATIONS_IN_APP_TABLE=app_notifications
NOTIFICATIONS_IN_APP_AUTO_CREATE_TABLE=false

NOTIFICATIONS_OUTBOX_ENABLED=false
NOTIFICATIONS_OUTBOX_CONNECTION=
NOTIFICATIONS_OUTBOX_TABLE=notification_outbox
NOTIFICATIONS_OUTBOX_AUTO_CREATE_TABLE=false
NOTIFICATIONS_OUTBOX_MAX_ATTEMPTS=5
NOTIFICATIONS_OUTBOX_BACKOFF_MS=500
NOTIFICATIONS_OUTBOX_CLAIM_BATCH_SIZE=100
NOTIFICATIONS_OUTBOX_CLAIM_LOCK_SECONDS=30

NOTIFICATIONS_REALTIME_ENABLED=false
NOTIFICATIONS_REALTIME_ENDPOINT=
NOTIFICATIONS_REALTIME_TIMEOUT_SECONDS=5
NOTIFICATIONS_REALTIME_SERVICE_ID=
NOTIFICATIONS_REALTIME_SERVICE_SECRET=

NOTIFICATIONS_DISPATCH_WORKER_ENABLED=false
NOTIFICATIONS_DISPATCH_WORKER_ID=dispatch-worker
NOTIFICATIONS_DISPATCH_WORKER_IDLE_SLEEP_MS=250

NOTIFICATIONS_RETRY_MAX_ATTEMPTS=1
NOTIFICATIONS_RETRY_BACKOFF_MS=250
